#!/usr/bin/env python3
"""haw-hello — an example haw plugin written in Python using the haw_plugin binding.

Install the binding (``pip install haw-plugin``) or run this from the repo. Drop
this file (named ``haw-hello``, executable) on PATH and haw will dispatch
``haw hello`` to it.

  - default:          prints a human greeting
  - --help:           prints usage
  - --format json:    emits a haw.plugin.report/1 document
  - render intent:    emits a haw.plugin.view/1 panel (HAW_RENDER=1)
"""

import os
import sys

# Allow running straight from the repo without installing.
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", ""))

from haw_plugin import Context, Finding, Report, view  # noqa: E402

HELP = """haw-hello (python) — example haw subcommand plugin

USAGE:
    haw hello [OPTIONS]

OPTIONS:
    -h, --help       Print this help
        --format json
                     Print a haw.plugin.report/1 JSON document on stdout
"""


def main() -> int:
    args = sys.argv[1:]

    if "-h" in args or "--help" in args:
        print(HELP)
        return 0

    ctx = Context.from_env()

    # Render intent: show a structured panel in the cockpit.
    if ctx.is_render():
        lines = [f"{r.get('name', '?')}  {r.get('rev', '?')}" for r in ctx.repos]
        if not lines:
            lines = ["(no repos in context)"]
        view("hello — fleet", lines)
        return 0

    if args[:2] == ["--format", "json"] or "--format=json" in args:
        rep = Report(
            plugin="hello",
            ok=True,
            summary="hello from haw-hello (python)",
        )
        for repo in ctx.repos:
            rep.findings.append(Finding("info", f"saw repo {repo.get('name')}"))
        rep.emit()
        return 0

    if ctx.root:
        print(f"hello from haw-hello (python) — workspace at {ctx.root}")
    else:
        print("hello from haw-hello (python) — no workspace here")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
